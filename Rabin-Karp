public class RabinKarp {
    public static void main(String[] args) {
        String text = "abcabcabc";
        String pattern = "abc";

        int n = text.length();
        int m = pattern.length();

        for (int i = 0; i <= n - m; i++) {
            if (text.substring(i, i + m).equals(pattern)) {
                System.out.println(i);
            }
        }
    }
}
