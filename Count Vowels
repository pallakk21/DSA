public class CountVowels {
    public static void main(String[] args) {
        String s = "hello world";

        int count = 0;

        for (char c : s.toCharArray()) {
            if (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u') {
                count++;
            }
        }

        System.out.println(count);
    }
}
